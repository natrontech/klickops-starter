# Local development config. Copy to .env - `make dev-backend` loads it.
# On klickops you never set these by hand: bind a PostgreSQL service and
# a Bucket service to the app and klickops injects them.

# HTTP port the server listens on
PORT=8080

# PostgreSQL (matches compose.yaml - `make services-up`)
DATABASE_URL=postgres://app:app@localhost:5432/app

# S3-compatible storage (matches compose.yaml)
S3_ENDPOINT=http://localhost:8333
S3_BUCKET=uploads
S3_ACCESS_KEY=dev
S3_SECRET_KEY=dev
# S3_REGION=us-east-1
