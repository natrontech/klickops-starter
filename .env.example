# Local development config. Copy to .env - `make dev-backend` loads it.
# On klickops you never set these by hand: bind a PostgreSQL service and
# a Bucket service to the app and klickops injects them.

# HTTP port the server listens on
PORT=8080

# PostgreSQL (matches compose.yaml - `make services-up`)
DATABASE_URL=postgres://app:app@localhost:5432/app

# S3-compatible storage (matches compose.yaml). These are the standard
# AWS SDK names - a klickops Bucket binding sets the same ones.
AWS_ENDPOINT_URL_S3=http://localhost:8333
S3_BUCKET=uploads
AWS_ACCESS_KEY_ID=dev
AWS_SECRET_ACCESS_KEY=dev
# AWS_REGION=us-east-1

# Valkey / Redis-compatible cache (matches compose.yaml). A klickops
# Valkey binding sets the same variable, including the password.
REDIS_URL=redis://localhost:6379/0
